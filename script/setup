#!/usr/bin/env bash

set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
OS="$(uname -s)"
LIMA_RELEASE_API_URL="${LIMA_RELEASE_API_URL:-https://api.github.com/repos/lima-vm/lima/releases/latest}"
LIMA_INSTALL_PREFIX="${LIMA_INSTALL_PREFIX:-/usr/local}"
SKIP_SYSTEM_PACKAGES=0
SKIP_PROJECT_SETUP=0

usage() {
  cat <<'EOF'
Usage: ./script/setup [--skip-system-packages] [--skip-project-setup] [--help]

Bootstraps a local TestLima development environment by:
  1. Installing required host packages with Homebrew on macOS or apt-get on Linux
  2. Installing Lima from the official binary archive on Linux when apt does not provide it
  3. Installing Hex and Rebar
  4. Running mix setup

Flags:
  --skip-system-packages  Skip Homebrew/apt-get package installation
  --skip-project-setup    Skip mix local.* and mix setup
  --help                  Show this help message

Notes:
  - macOS requires Xcode Command Line Tools before Homebrew packages can be installed
  - The app installs Node and Codex inside the Lima VM when a thread starts
EOF
}

status() {
  printf '[setup] %s\n' "$1"
}

warn() {
  printf '[setup] warning: %s\n' "$1" >&2
}

fail() {
  printf '[setup] error: %s\n' "$1" >&2
  exit 1
}

have() {
  command -v "$1" >/dev/null 2>&1
}

run() {
  printf '[setup] +'
  printf ' %q' "$@"
  printf '\n'
  "$@"
}

run_with_sudo() {
  if [[ "${EUID}" -eq 0 ]]; then
    run "$@"
  elif have sudo; then
    run sudo "$@"
  else
    fail "sudo is required to install system packages"
  fi
}

ensure_macos_build_tools() {
  if [[ "${OS}" != "Darwin" ]]; then
    return
  fi

  if ! xcode-select -p >/dev/null 2>&1; then
    fail "Xcode Command Line Tools are required. Run 'xcode-select --install' and rerun ./script/setup."
  fi
}

brew_install_if_missing() {
  local formula="$1"

  if brew list --versions "${formula}" >/dev/null 2>&1; then
    status "Homebrew formula already installed: ${formula}"
  else
    run brew install "${formula}"
  fi
}

install_with_brew() {
  ensure_macos_build_tools
  status "Installing host dependencies with Homebrew"
  run brew update

  local formulae=(
    elixir
    node
    lima
  )

  local formula
  for formula in "${formulae[@]}"; do
    brew_install_if_missing "${formula}"
  done
}

apt_package_available() {
  apt-cache show "$1" >/dev/null 2>&1
}

fetch_lima_version() {
  if [[ -n "${LIMA_VERSION:-}" ]]; then
    printf '%s\n' "${LIMA_VERSION}"
    return
  fi

  local version
  version="$(
    curl -fsSL "${LIMA_RELEASE_API_URL}" |
      sed -n 's/.*"tag_name"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' |
      head -n 1
  )"

  if [[ -z "${version}" ]]; then
    fail "Unable to determine the latest Lima release from ${LIMA_RELEASE_API_URL}"
  fi

  printf '%s\n' "${version}"
}

download_file() {
  local url="$1"
  local target="$2"

  run curl -fsSL -o "${target}" "${url}"
}

extract_archive() {
  local archive="$1"
  local prefix="$2"
  local parent_dir
  parent_dir="$(dirname "${prefix}")"

  if [[ -d "${prefix}" && -w "${prefix}" ]]; then
    run tar -C "${prefix}" -xzf "${archive}"
  elif [[ -w "${parent_dir}" ]]; then
    run mkdir -p "${prefix}"
    run tar -C "${prefix}" -xzf "${archive}"
  else
    run_with_sudo mkdir -p "${prefix}"
    run_with_sudo tar -C "${prefix}" -xzf "${archive}"
  fi
}

add_prefix_bin_to_path() {
  local prefix="$1"
  local bin_dir="${prefix}/bin"

  if [[ -d "${bin_dir}" && ":${PATH}:" != *":${bin_dir}:"* ]]; then
    PATH="${bin_dir}:${PATH}"
    export PATH
  fi
}

install_lima_binary_archive() {
  if have lima && have limactl; then
    status "Lima is already installed"
    return
  fi

  local version archive_version platform archive_url guestagents_url tmp_dir archive_path guestagents_path
  version="$(fetch_lima_version)"
  archive_version="${version#v}"
  platform="$(uname -s)-$(uname -m)"
  archive_url="https://github.com/lima-vm/lima/releases/download/${version}/lima-${archive_version}-${platform}.tar.gz"
  guestagents_url="https://github.com/lima-vm/lima/releases/download/${version}/lima-additional-guestagents-${archive_version}-${platform}.tar.gz"
  tmp_dir="$(mktemp -d)"
  archive_path="${tmp_dir}/lima.tar.gz"
  guestagents_path="${tmp_dir}/lima-additional-guestagents.tar.gz"

  status "Installing Lima ${version} from the official binary archive"
  download_file "${archive_url}" "${archive_path}"
  extract_archive "${archive_path}" "${LIMA_INSTALL_PREFIX}"

  status "Installing Lima guest agents ${version}"
  download_file "${guestagents_url}" "${guestagents_path}"
  extract_archive "${guestagents_path}" "${LIMA_INSTALL_PREFIX}"

  add_prefix_bin_to_path "${LIMA_INSTALL_PREFIX}"
  rm -rf "${tmp_dir}"
}

install_with_apt() {
  status "Installing host dependencies with apt-get"

  local packages=(
    build-essential
    curl
    elixir
    erlang
    git
    inotify-tools
    nodejs
    npm
    qemu-system-arm
    qemu-system-x86
    qemu-utils
    sqlite3
    uidmap
  )

  local install_lima_from_archive=0

  if have apt-cache && apt_package_available lima; then
    packages+=(lima)
  else
    install_lima_from_archive=1
    warn "No apt package named 'lima' was found. Installing Lima from the official binary archive instead."
  fi

  run_with_sudo apt-get update
  run_with_sudo apt-get install -y "${packages[@]}"

  if [[ "${install_lima_from_archive}" -eq 1 ]]; then
    install_lima_binary_archive
  fi
}

install_system_packages() {
  if [[ "${OS}" == "Darwin" ]]; then
    if have brew; then
      install_with_brew
      return
    fi

    fail "Homebrew is required on macOS. Install it from https://brew.sh and rerun ./script/setup."
  fi

  if have apt-get; then
    install_with_apt
    return
  fi

  fail "Unsupported Linux package manager. Install Elixir, Node.js, and Lima manually, then rerun with --skip-system-packages."
}

verify_required_commands() {
  local required_commands=(
    elixir
    mix
    node
    npm
    lima
    limactl
  )
  local missing=()
  local command_name

  for command_name in "${required_commands[@]}"; do
    if ! have "${command_name}"; then
      missing+=("${command_name}")
    fi
  done

  if [[ "${#missing[@]}" -gt 0 ]]; then
    fail "Missing required commands: ${missing[*]}"
  fi
}

run_project_setup() {
  status "Installing project dependencies"
  cd "${ROOT_DIR}"
  run mix local.hex --force
  run mix local.rebar --force
  run mix setup
}

while [[ "${#}" -gt 0 ]]; do
  case "$1" in
    --skip-system-packages)
      SKIP_SYSTEM_PACKAGES=1
      ;;
    --skip-project-setup)
      SKIP_PROJECT_SETUP=1
      ;;
    --help|-h)
      usage
      exit 0
      ;;
    *)
      usage
      fail "Unknown option: $1"
      ;;
  esac
  shift
done

if [[ "${SKIP_SYSTEM_PACKAGES}" -eq 0 ]]; then
  install_system_packages
fi

verify_required_commands

if [[ "${SKIP_PROJECT_SETUP}" -eq 0 ]]; then
  run_project_setup
fi

status "Environment is ready"
status "Start the app with: mix phx.server"
