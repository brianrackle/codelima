+pub fn get_hyperlink_uri(
+    terminal_: Terminal,
+    row: c_int,
+    col: c_int,
+    out: [*]u8,
+    buf_size: usize,
+) callconv(.c) c_int {
+    const t: *ZigTerminal = (terminal_ orelse return -1).terminal;
+    if (row < 0 or col < 0) return -1;
+
+    const pin = t.screens.active.pages.pin(.{ .active = .{ .y = @intCast(row) } }) orelse return -1;
+    const cells = pin.cells(.all);
+    const page = pin.node.data;
+    const x: usize = @intCast(col);
+    if (x >= cells.len) return -1;
+
+    const cell = &cells[x];
+    if (!cell.hyperlink) return 0;
+
+    const hyperlink_id = page.lookupHyperlink(cell) orelse return 0;
+    const hyperlink = page.hyperlink_set.get(page.memory, hyperlink_id);
+    const uri = hyperlink.uri.slice(page.memory);
+    if (uri.len == 0) return 0;
+    if (buf_size < uri.len) return -1;
+
+    @memcpy(out[0..uri.len], uri);
+    return @intCast(uri.len);
+}
+
+pub fn get_scrollback_hyperlink_uri(
+    terminal_: Terminal,
+    offset: c_int,
+    col: c_int,
+    out: [*]u8,
+    buf_size: usize,
+) callconv(.c) c_int {
+    const t: *ZigTerminal = (terminal_ orelse return -1).terminal;
+    if (offset < 0 or col < 0) return -1;
+
+    const scrollback_len = t.screens.active.pages.total_rows - t.rows;
+    if (@as(usize, @intCast(offset)) >= scrollback_len) return -1;
+
+    const pin = t.screens.active.pages.pin(.{ .history = .{ .y = @intCast(offset) } }) orelse return -1;
+    const cells = pin.cells(.all);
+    const page = pin.node.data;
+    const x: usize = @intCast(col);
+    if (x >= cells.len) return -1;
+
+    const cell = &cells[x];
+    if (!cell.hyperlink) return 0;
+
+    const hyperlink_id = page.lookupHyperlink(cell) orelse return 0;
+    const hyperlink = page.hyperlink_set.get(page.memory, hyperlink_id);
+    const uri = hyperlink.uri.slice(page.memory);
+    if (uri.len == 0) return 0;
+    if (buf_size < uri.len) return -1;
+
+    @memcpy(out[0..uri.len], uri);
+    return @intCast(uri.len);
+}
+
 pub fn free(terminal_: Terminal) callconv(.c) void {
     const wrapper = terminal_ orelse return;
     const t = wrapper.terminal;
